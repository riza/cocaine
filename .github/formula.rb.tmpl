class Cocaine < Formula
  desc "Keep your Mac awake. Like caffeinate, but with more kick."
  homepage "https://github.com/riza/cocaine"
  version "@@VERSION@@"
  license "MIT"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/riza/cocaine/releases/download/v@@VERSION@@/cocaine-aarch64-apple-darwin.tar.gz"
      sha256 "@@SHA_ARM@@"
    else
      url "https://github.com/riza/cocaine/releases/download/v@@VERSION@@/cocaine-x86_64-apple-darwin.tar.gz"
      sha256 "@@SHA_X86@@"
    end
  end

  def install
    bin.install "cocaine"
  end

  test do
    assert_match "cocaine", shell_output("#{bin}/cocaine --version")
  end
end
